rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }

    // Collection: Businesses
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(businessId);
    }

    // Collection: Customers
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(customerId);
    }

    // Collection: Relations
    match /customer_business_relations/{relationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(relationId);
    }

    // Collection: Payment Transactions
    match /payment_transactions/{txnId} {
      allow read, write: if isSignedIn() && isValidId(txnId);
    }

    // Collection: Notifications
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(notifId);
    }

    // Collection: Audit Logs
    match /audit_logs/{logId} {
      allow read, write: if isSignedIn() && isValidId(logId);
    }

    // Collection: System / Config
    match /system/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(docId);
    }
  }
}
